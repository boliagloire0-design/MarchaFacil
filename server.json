            <input type="password" name="passcode" placeholder="Passcode" style="width:100%; padding:15px; margin-bottom:10px; border-radius:10px; border:1px solid #333; background:#111; color:white;">
            <button>Entrar / Login</button>
        </form>
    </div></body></html>`);
