// =============================================================
// ✅ DATA SCHEMA (1 Year Lock / 5% Monthly)
// =============================================================
const userSchema = new mongoose.Schema({
    email: { type: String, unique: true, required: true },
    passcode: String,
    name: String,
    phone: String,
    balance: { type: Number, default: 0 },
    investments: [{ 
        capital: Number, 
        monthlyProfit: Number, 
        lastPayout: Date, 
        expiryDate: Date 
    }],
    pendingDeposit: { amount: Number, status: String, date: Date },
    transactions: [{ type: { type: String }, amount: Number, date: String }]
});
const User = mongoose.model('User', userSchema);

// =============================================================
// ✅ LOGIC: INVESTMENTS & CLAIMS
// =============================================================

// Admin confirms deposit -> Starts 1 Year Lock
app.post('/confirm', async (req, res) => {
    const u = await User.findById(req.body.uid);
    if (u && u.pendingDeposit) {
        const amt = u.pendingDeposit.amount;
        const now = new Date();
        const expiry = new Date();
        expiry.setFullYear(now.getFullYear() + 1); 

        u.investments.push({ 
            capital: amt, 
            monthlyProfit: amt * 0.05, 
            lastPayout: now,
            expiryDate: expiry
        });
        u.transactions.push({ type: "Deposit Locked", amount: amt, date: now.toLocaleDateString() });
        u.pendingDeposit = null;
        await u.save();
    }
    res.redirect('/admin');
});

// User claims 5% profit every 30 days
app.post('/claim', async (req, res) => {
    const u = await User.findById(req.session.userId);
    const now = new Date();
    let totalClaimed = 0;

    u.investments.forEach(inv => {
        const daysSincePayout = Math.floor((now - inv.lastPayout) / (1000 * 60 * 60 * 24));
        if (daysSincePayout >= 30) {
            totalClaimed += inv.monthlyProfit;
            inv.lastPayout = now;
        }
        if (now >= inv.expiryDate && inv.capital > 0) {
            totalClaimed += inv.capital;
            inv.capital = 0; 
        }
    });

    if (totalClaimed > 0) {
        u.balance += totalClaimed;
        u.transactions.push({ type: "Profit Payout", amount: totalClaimed, date: now.toLocaleDateString() });
        await u.save();
    }
    res.redirect('/dashboard');
});

