app.post('/login', async (req, res) => {
    const user = await User.findOne({ email: req.body.email.toLowerCase() });
    if (user && user.passcode === req.body.passcode) {
        req.session.userId = user._id;
        res.redirect('/dashboard');
    } else {
        res.send("Invalid credentials. <a href='/'>Go back</a>");
    }
});

app.get('/dashboard', async (req, res) => {
    if (!req.session.userId) return res.redirect('/');
    const u = await User.findById(req.session.userId);
    
    let locked = 0;
    u.investments.forEach(inv => locked += inv.capital);

    res.send(`<html><head><meta name="viewport" content="width=device-width,initial-scale=1"><style>${css}</style></head><body>
    <div class="container">
        <h2 style="text-align:center;">MarchaFácil Portal</h2>
        <div class="balance-card">
            <small>Saldo Disponível (Available)</small>
            <div style="font-size:35px; font-weight:800;">$${u.balance.toFixed(2)}</div>
            <div style="margin-top:10px; font-size:14px; opacity:0.8;">Locked Capital: $${locked.toFixed(2)}</div>
        </div>

        <div class="card">
            <h3>5% Monthly Profit</h3>
            <p style="font-size:12px; color:#848e9c;">Profits are generated every 30 days. Capital is locked for 1 year.</p>
            <form action="/claim" method="POST"><button>Collect Earnings</button></form>
        </div>

        <div class="support-grid">
            <a href="${WHATSAPP_LINK}" class="btn-wa">WhatsApp</a>
            <a href="${TELEGRAM_LINK}" class="btn-tg">Telegram</a>
        </div>
        
        <p style="text-align:center; font-size:11px; color:#444; margin-top:30px;">MARCHAFÁCIL © 2026<br>Secure Investment Protocol</p>
    </div></body></html>`);
});

